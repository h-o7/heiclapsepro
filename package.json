{
  "name": "chronos-pro-studio",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "main": "electron.bundle.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js dist-electron electron.bundle.cjs",
    "lint": "tsc --noEmit",
    "electron:build": "esbuild electron.cjs --bundle --platform=node --external:electron --external:heic-convert --outfile=electron.bundle.cjs",
    "electron:start": "npm run electron:build && electron .",
    "electron:pack": "npm run build && npm run electron:build && electron-builder --dir",
    "electron:dist": "npm run build && npm run electron:build && electron-builder",
    "package": "npm run build && npm run electron:build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "heic-convert": "^2.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^33.2.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "appId": "com.chronos.pro",
    "productName": "Chronos Pro Studio",
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "electron.bundle.cjs",
      "preload.cjs",
      "package.json"
    ],
    "directories": {
      "output": "dist-electron"
    }
  }
}
